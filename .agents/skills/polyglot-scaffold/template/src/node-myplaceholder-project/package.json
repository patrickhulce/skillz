{
  "name": "myplaceholder-npm-pkg",
  "version": "0.1.0",
  "description": "Node.js bindings for myplaceholder-project",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "files": [
    "dist",
    "binding.js",
    "binding.d.ts",
    "*.node"
  ],
  "scripts": {
    "build:native": "napi build --cargo-name myplaceholder_node_bindings --platform --release --js binding.js --dts binding.d.ts",
    "build:ts": "tsc",
    "build": "pnpm run build:native && pnpm run build:ts",
    "build:debug": "napi build --cargo-name myplaceholder_node_bindings --platform --js binding.js --dts binding.d.ts && pnpm run build:ts",
    "test": "node --import tsx --test test/echo.test.ts",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint --fix . && prettier --write .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@napi-rs/cli": "^2.18.4",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2"
  },
  "napi": {
    "name": "myplaceholder-napi-name"
  }
}
