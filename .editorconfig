root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.{py,yml,yaml,toml,json,rs,ts,mjs,sh}]
indent_style = space
indent_size = 4

[*.{ts,mjs,json,yml,yaml}]
indent_size = 2
